# Sextant — variables d'environnement (calquées sur BBIscout, CLAUDE.md §7)

# Postgres Railway
DATABASE_URL=postgres://user:pass@host:5432/railway

# Secret partagé pour /api/ingest et /api/seed (scrapers n8n)
INGEST_SECRET=change-me

# Webhooks scrapers n8n Railway
N8N_WEBHOOK_URL=
N8N_IMMOTOP_WEBHOOK_URL=

# Optionnel : classification état atHome via Claude
ANTHROPIC_API_KEY=

# URL publique de l'app
PUBLIC_APP_URL=http://localhost:3000
